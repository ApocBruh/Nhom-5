                <a href="/category" class="btn btn-dark btn-sm mb-2">Sports</a>
                <a href="/category" class="btn btn-dark btn-sm mb-2">Politics</a>
                <a href="/category" class="btn btn-dark btn-sm mb-2">Health</a>
                <a href="/category" class="btn btn-dark btn-sm mb-2">Technology</a>
                <a href="/category" class="btn btn-dark btn-sm mb-2">Science</a>
            </div>
        </div>

        <!-- COLUMN 4: NEWSLETTER -->
        <div class="col-lg-3 col-md-6 mb-5">
            <h5 class="text-white font-weight-bold mb-4">Newsletter</h5>
